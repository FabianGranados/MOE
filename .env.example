# ====================================================================
# MOE · Variables de entorno
#
# Copia este archivo como .env.local y rellena con los valores reales.
# El archivo .env.local NO se sube al repo (está en .gitignore).
# ====================================================================

# Credenciales de Supabase
# Dónde encontrarlas:
#   1. Entra a https://supabase.com/dashboard
#   2. Elige tu proyecto (si no tienes, créalo)
#   3. Settings → API
#   4. Copia "Project URL" y "anon public"
#
# Si dejas estas variables vacías, MOE corre en modo demo con localStorage.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
